# Local development values. Generate unique production secrets and configure
# them in the hosting provider; never commit a populated backend/.env file.
DEBUG=True
SECRET_KEY=replace-with-a-random-local-or-production-value
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
SCRAPER_API_KEY=replace-with-a-separate-random-scraper-key

# Database Configuration
# If these are not set, Django will default to SQLite for local development
DB_NAME=savebasket
DB_USER=savebasket
DB_PASSWORD=replace-with-database-password
DB_HOST=127.0.0.1
DB_PORT=5432
